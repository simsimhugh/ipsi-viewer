{
  "name": "ipsi-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "fetch:schools": "tsx scripts/fetch-schools.ts",
    "scrape:school": "tsx scripts/scrape-schoolinfo.ts",
    "convert:districts": "tsx scripts/convert-districts.ts",
    "build:master": "tsx scripts/build-school-master.ts",
    "filter:master": "tsx scripts/filter-master.ts",
    "fetch:career": "tsx scripts/fetch-career.ts",
    "batch:fetch": "tsx scripts/batch-fetch.ts",
    "join:careers": "tsx scripts/join-careers.ts",
    "analyze:careers": "tsx scripts/analyze-careers.ts",
    "check:data": "tsx scripts/check-data-integrity.ts",
    "check:data:fixture": "HAKGUN_DATA_DIR=$PWD/data/fixtures tsx scripts/check-data-integrity.ts",
    "import:supabase": "tsx scripts/import-to-supabase.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "setup:hooks": "cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push && echo 'pre-push hook installed'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "csv-parse": "^5.6.0",
    "next": "^14.2.18",
    "playwright": "^1.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
